# Location Voiture Tunisie 24/7 — Environment Variables
# Copy to .env.local and fill in real values before running

# Backend API (admin platform)
BACKEND_API_URL=https://api.yourdomain.com/api/v1
SITE_SLUG=location-voiture-tunisie-24-7

# Generate this key from the admin dashboard:
# Admin → Sites → locationvoituretunisie24-7.com → API Keys → Create
SITE_API_KEY=

# Optional: override the domain used in next.config.js for image remotePatterns
SITE_DOMAIN=locationvoituretunisie24-7.com
